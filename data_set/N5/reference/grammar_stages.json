  "stage_1_foundation": {
    "description": "Survival Japanese - Basic sentences, copula, particles, present tense",
    "target_sentences": "200-700",
    "difficulty_range": [1, 3],
    "formality_target": 0.90,
    "patterns": [
      {
        "pattern": "です",
        "description": "polite copula (is/am/are)",
        "prerequisites": [],
        "example": "これは本です。",
        "priority": "critical"
      },
      {
        "pattern": "だ",
        "description": "plain copula (is/am/are)",
        "prerequisites": [],
        "example": "これは本だ。",
        "priority": "critical"
      },
      {
        "pattern": "は",
        "description": "topic marker",
        "prerequisites": [],
        "example": "私は学生です。",
        "priority": "critical"
      },
      {
        "pattern": "が",
        "description": "subject marker",
        "prerequisites": [],
        "example": "犬がいます。",
        "priority": "critical"
      },
      {
        "pattern": "を",
        "description": "object marker",
        "prerequisites": [],
        "example": "本を読みます。",
        "priority": "critical"
      },
      {
        "pattern": "に",
        "description": "location/time/indirect object marker",
        "prerequisites": [],
        "example": "学校に行きます。",
        "priority": "critical"
      },
      {
        "pattern": "で",
        "description": "means/location of action marker",
        "prerequisites": [],
        "example": "駅で会います。",
        "priority": "critical"
      },
      {
        "pattern": "か",
        "description": "question marker",
        "prerequisites": [],
        "example": "これは何ですか。",
        "priority": "critical"
      },
      {
        "pattern": "い",
        "description": "i-adjective present",
        "prerequisites": [],
        "example": "今日は暑いです。",
        "priority": "critical"
      },
      {
        "pattern": "な",
        "description": "na-adjective",
        "prerequisites": [],
        "example": "静かな部屋です。",
        "priority": "critical"
      },
      {
        "pattern": "ます",
        "description": "polite present verb ending",
        "prerequisites": [],
        "example": "行きます。",
        "priority": "critical"
      },
      {
        "pattern": "も",
        "description": "also, too",
        "prerequisites": ["は"],
        "example": "私も学生です。",
        "priority": "high"
      }
    ]
  },

  "stage_2_core_verbs": {
