        "description": "te-form connector",
        "prerequisites": ["ます", "た"],
        "example": "食べて飲みます。",
        "priority": "critical"
      },
      {
        "pattern": "てください",
        "description": "please do",
        "prerequisites": ["て"],
        "example": "待ってください。",
        "priority": "critical"
      },
      {
        "pattern": "ている",
        "description": "progressive/state plain",
        "prerequisites": ["て"],
        "example": "食べている。",
        "priority": "critical"
      },
      {
        "pattern": "ています",
